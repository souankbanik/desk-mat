<div class="navbar-wrapper">
  <div class="container">
    <nav class="navbar">
      <div style="display: flex; align-items: center; gap: 8px;">
        <button 
          class="hamburger-btn" 
          aria-label="Toggle mobile menu"
          style="position: relative; z-index: 110;"
          onclick="this.classList.toggle('open'); document.querySelector('.nav-links').classList.toggle('mobile-open');"
        >
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
        <a href="{{ routes.root_url }}" class="nav-logo" style="display: flex; align-items: center;">
          <div class="nav-logo-img-wrapper" style="position: relative; height: 60px; display: flex; align-items: center; justify-content: center; margin-left: 5px;">
            {% if section.settings.logo != blank %}
              <img 
                src="{{ section.settings.logo | image_url: height: 120 }}" 
                alt="{{ shop.name }}" 
                style="max-height: 40px; width: auto;"
              >
            {% else %}
              <span style="font-size: 24px; font-weight: bold; font-family: var(--font-michroma);">{{ shop.name }}</span>
            {% endif %}
          </div>
        </a>
      </div>
      <div class="nav-links">
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}" class="nav-link">{{ link.title }}</a>
        {% endfor %}
      </div>
      <div class="nav-actions" style="display: flex; align-items: center; gap: 10px; margin-right: -20px; position: relative; z-index: 110;">
        <a href="{{ routes.search_url }}" class="nav-icon" aria-label="Search" style="padding: 4px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </a>
        <a href="{{ routes.account_url }}" class="nav-icon" aria-label="Account" style="padding: 4px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
        <a href="{{ routes.cart_url }}" class="nav-icon" aria-label="Cart" style="padding: 4px; display: flex; align-items: center; position: relative;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
          {% if cart.item_count > 0 %}
            <span class="cart-badge" style="position: absolute; top: -2px; right: -4px; background: var(--color-primary); color: white; font-size: 0.65rem; font-weight: bold; width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; border-radius: 50%;">{{ cart.item_count }}</span>
          {% endif %}
        </a>
      </div>
    </nav>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    }
  ]
}
{% endschema %}

<section class="banner-carousel-section">
  <div class="banner-carousel-wrapper" data-slideshow>
    <div class="banner-carousel-scroll-container" data-slideshow-container>
      {% for block in section.blocks %}
        <div class="banner-slide" {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            <img 
              src="{{ block.settings.image | image_url: width: 2000 }}" 
              alt="{{ block.settings.image.alt | escape }}" 
              class="banner-image"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            >
          {% else %}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'banner-image' }}
          {% endif %}
          
          <div class="banner-content">
            <h1 class="banner-title">{{ block.settings.title }}</h1>
            <p class="banner-subtitle">{{ block.settings.subtitle }}</p>
            {% if block.settings.button_link != blank %}
              <a href="{{ block.settings.button_link }}" class="banner-cta">
                {{ block.settings.button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    
    <!-- Next/Prev Buttons omitted for brevity; would require custom JS in Shopify -->
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "ELEVATE YOUR SETUP"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subheading",
          "default": "Premium Desk Mats for Professionals"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
